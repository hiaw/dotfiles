
# Kiro/Fig shell integration wraps zle widgets and prompt redraw. After a
# restart this caused duplicated/interleaved input in plain zsh, so keep it off.
# [[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh"

#
# Executes commands at the start of an interactive session.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

# Avoid repeated autosuggestion widget rebinding on every prompt redraw.
export ZSH_AUTOSUGGEST_MANUAL_REBIND=1

# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Synchronous suggestions are less prone to redraw races in terminal emulators.
unset ZSH_AUTOSUGGEST_USE_ASYNC

# Local secrets (API keys, tokens) - not committed to git
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS
setopt IGNORE_EOF

# alias lg='lazygit'
# alias lz='lazygit'
alias nv='nvim'
alias oc='opencode'

# Load Angular CLI autocompletion.
# source <(ng completion script)

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
# CLAUDE_CODE
# export CLAUDE_CODE_USE_BEDROCK=1
# export DISABLE_PROMPT_CACHING=1
eval "$(mise activate zsh)"

# The next line updates PATH for the Google Cloud SDK.
if [ -f "$HOME/Downloads/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/Downloads/google-cloud-sdk/path.zsh.inc"; fi

# The next line enables shell command completion for gcloud.
if [ -f "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc"; fi

source_fzf_zsh() {
  # fzf's zsh scripts restore the special `zle` option and zsh prints a
  # harmless warning for it. Filter only that known warning during startup.
  source "$1" 2> >(command grep -v "can't change option: zle" >&2)
}

# 1. AlmaLinux / RHEL standard package manager (dnf) paths
if [[ -f "/usr/share/fzf/shell/key-bindings.zsh" ]]; then
  source_fzf_zsh "/usr/share/fzf/shell/key-bindings.zsh"
  source_fzf_zsh "/usr/share/fzf/shell/completion.zsh"

# 2. Manual Git installation path (if you ran the ~/.fzf/install script)
elif [[ -f "$HOME/.fzf.zsh" ]]; then
  source_fzf_zsh "$HOME/.fzf.zsh"

# 3. macOS / Homebrew paths
elif [[ -n "$HOMEBREW_PREFIX" ]] && [[ -f "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh" ]]; then
  source_fzf_zsh "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh"
  source_fzf_zsh "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh"
fi

# Make fzf use fd for the default search
export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git --exclude node_modules'

# Apply it to ctrl-T (if you use that shortcut)
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# Apply it to the **<TAB> completion you were just using
_fzf_compgen_path() {
  fd --hidden --exclude .git --exclude node_modules . "$1"
}

# Apply it to directory completion like `cd **<TAB>`
_fzf_compgen_dir() {
  fd --type d --hidden --exclude .git --exclude node_modules . "$1"
}

# Set up fzf to use bat for file previews on ctrl-T
# (If you are on Ubuntu/Debian, change 'bat' to 'batcat' in the line below)
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}'"

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

