
# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh"

#
# Executes commands at the start of an interactive session.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Local secrets (API keys, tokens) - not committed to git
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# Customize to your needs...
export PNPM_HOME="${ZDOTDIR:-$HOME}/.local/share/pnpm"
export HOMEBREW_PREFIX="/opt/homebrew";
export HOMEBREW_CELLAR="/opt/homebrew/Cellar";
export HOMEBREW_REPOSITORY="/opt/homebrew";
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin${PATH+:$PATH}";
export MANPATH="/opt/homebrew/share/man${MANPATH+:$MANPATH}:";
export INFOPATH="/opt/homebrew/share/info:${INFOPATH:-}";

setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS
setopt IGNORE_EOF

# alias lg='lazygit'
# alias lz='lazygit'
alias nv='nvim'
alias oc='opencode'

# Load Angular CLI autocompletion.
# source <(ng completion script)

# pnpm
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# sst
export PATH=$HOME/.sst/bin:$PATH

export PATH=$HOME/Documents/flutter/ff_flutter_sdk/flutter/bin/:$PATH

export PATH="$PATH":"$HOME/.pub-cache/bin"

export CC="ccache clang"
export CXX="ccache clang++"
export PATH="$HOMEBREW_PREFIX/opt/ccache/libexec:${PATH}"

export JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home

export ANDROID_HOME=$HOME/Library/Android/sdk 
export PATH=$PATH:$ANDROID_HOME/emulator 
export PATH=$PATH:$ANDROID_HOME/platform-tools

# CLAUDE_CODE
# export CLAUDE_CODE_USE_BEDROCK=1
# export DISABLE_PROMPT_CACHING=1

# opencode
export PATH=$HOME/.opencode/bin:$PATH

eval "$(mise activate zsh)"

# The next line updates PATH for the Google Cloud SDK.
if [ -f "$HOME/Downloads/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/Downloads/google-cloud-sdk/path.zsh.inc"; fi

# The next line enables shell command completion for gcloud.
if [ -f "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc"; fi

# Added by Antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

source "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh"
source "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh"

# Make fzf use fd for the default search
export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git --exclude node_modules'

# Apply it to ctrl-T (if you use that shortcut)
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# Apply it to the **<TAB> completion you were just using
_fzf_compgen_path() {
  fd --hidden --exclude .git --exclude node_modules . "$1"
}

# Apply it to directory completion like `cd **<TAB>`
_fzf_compgen_dir() {
  fd --type d --hidden --exclude .git --exclude node_modules . "$1"
}

# Set up fzf to use bat for file previews on ctrl-T
# (If you are on Ubuntu/Debian, change 'bat' to 'batcat' in the line below)
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}'"

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# Kiro CLI post block. Keep at the bottom of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh"
